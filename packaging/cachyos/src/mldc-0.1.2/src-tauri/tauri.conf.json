{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minimal Linux Disk Cloner",
  "version": "0.1.2",
  "identifier": "com.chris.mldc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Minimal Linux Disk Cloner",
        "width": 1480,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 820,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
