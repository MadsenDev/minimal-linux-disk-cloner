pkgname=mldc
pkgver=0.1.0
pkgrel=1
pkgdesc="Clone and verify physical drives on Linux with a native Tauri desktop UI"
arch=('x86_64')
url="https://github.com/MadsenDev/minimal-linux-disk-cloner"
license=('MIT')
depends=(
  'gtk3'
  'webkit2gtk-4.1'
  'libsoup3'
  'hicolor-icon-theme'
)
makedepends=(
  'cargo'
  'rust'
  'nodejs'
  'npm'
)
provides=('mldc')
conflicts=('mldc-git')
source=("mldc-$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "$srcdir/mldc-$pkgver"

  export CARGO_HOME="$srcdir/cargo-home"
  export npm_config_cache="$srcdir/npm-cache"

  npm ci
}

build() {
  cd "$srcdir/mldc-$pkgver"

  export CARGO_HOME="$srcdir/cargo-home"
  export npm_config_cache="$srcdir/npm-cache"

  npm run tauri:build
}

package() {
  cd "$srcdir/mldc-$pkgver"

  install -Dm755 "src-tauri/target/release/mldc-tauri" \
    "$pkgdir/usr/lib/mldc/mldc"
  install -Dm755 "packaging/linux/mldc-launcher.sh" \
    "$pkgdir/usr/bin/mldc"
  install -Dm644 "packaging/linux/mldc.desktop" \
    "$pkgdir/usr/share/applications/mldc.desktop"
  install -Dm644 "assets/mldc.svg" \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/mldc.svg"

  for size in 32x32 64x64 128x128; do
    install -Dm644 "src-tauri/icons/$size.png" \
      "$pkgdir/usr/share/icons/hicolor/$size/apps/mldc.png"
  done
}
